generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = "postgresql://neondb_owner:npg_oPOpqvfy8a9h@ep-lively-term-abwi3v6b.eu-west-2.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
  directUrl = "postgresql://neondb_owner:npg_oPOpqvfy8a9h@ep-lively-term-abwi3v6b.eu-west-2.aws.neon.tech/neondb?sslmode=require"
}

model accounts {
  id                String  @id
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  users             users   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model inquiries {
  id           String        @id
  subject      String
  status       InquiryStatus @default(OPEN)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime
  wholesalerId String
  productId    String
  products     products      @relation(fields: [productId], references: [id], onDelete: Cascade)
  users        users         @relation(fields: [wholesalerId], references: [id], onDelete: Cascade)
  messages     messages[]

  @@index([createdAt])
  @@index([productId])
  @@index([status])
  @@index([wholesalerId])
}

model messages {
  id        String    @id
  body      String
  createdAt DateTime  @default(now())
  inquiryId String
  senderId  String
  inquiries inquiries @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  users     users     @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([inquiryId])
}

model orders {
  id                 String      @id
  yardsOrdered       Int
  totalAmountInCents Int
  status             OrderStatus @default(PENDING)
  createdAt          DateTime    @default(now())
  userId             String
  productId          String
  products           products    @relation(fields: [productId], references: [id], onDelete: Cascade)
  users              users       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([productId])
  @@index([status])
  @@index([userId])
}

model products {
  id                    String      @id
  name                  String
  description           String?
  imageUrl              String?
  category              String
  retailPricePerYard    Int
  wholesalePricePerYard Int
  totalYardsInStock     Int         @default(0)
  createdAt             DateTime    @default(now())
  updatedAt             DateTime
  inquiries             inquiries[]
  orders                orders[]

  @@index([category])
  @@index([createdAt])
}

model sessions {
  id           String   @id
  sessionToken String   @unique
  userId       String
  expires      DateTime
  users        users    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model users {
  id        String      @id
  email     String      @unique
  password  String?
  name      String?
  role      Role        @default(GUEST)
  createdAt DateTime    @default(now())
  updatedAt DateTime
  accounts  accounts[]
  inquiries inquiries[]
  messages  messages[]
  orders    orders[]
  sessions  sessions[]

  @@index([createdAt])
}

model verification_tokens {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum InquiryStatus {
  OPEN
  REPLIED
  CLOSED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum Role {
  GUEST
  WHOLESALER
  ADMIN
}
