generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model accounts {
  id                String  @id
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  users             users   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model inquiries {
  id           String        @id
  subject      String
  status       InquiryStatus @default(OPEN)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime
  wholesalerId String
  productId    String
  products     products      @relation(fields: [productId], references: [id], onDelete: Cascade)
  users        users         @relation(fields: [wholesalerId], references: [id], onDelete: Cascade)
  messages     messages[]

  @@index([createdAt])
  @@index([productId])
  @@index([status])
  @@index([wholesalerId])
}

model messages {
  id        String    @id
  body      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now())
  inquiryId String
  senderId  String
  inquiries inquiries @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  users     users     @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([inquiryId])
}

model orders {
  id                 String        @id
  yardsOrdered       Int
  totalAmountInCents Int
  status             OrderStatus   @default(PENDING)
  paymentMethod      PaymentMethod @default(BANK_TRANSFER)
  paymentRef         String?
  notes              String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @default(now())
  userId             String
  productId          String
  products           products      @relation(fields: [productId], references: [id], onDelete: Cascade)
  users              users         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([productId])
  @@index([paymentMethod])
  @@index([status])
  @@index([userId])
}

model products {
  id                    String      @id
  name                  String
  description           String?
  imageUrl              String?
  category              String
  retailPricePerYard    Int
  wholesalePricePerYard Int
  totalYardsInStock     Int         @default(0)
  createdAt             DateTime    @default(now())
  updatedAt             DateTime
  inquiries             inquiries[]
  orders                orders[]

  @@index([category])
  @@index([createdAt])
}

model sessions {
  id           String   @id
  sessionToken String   @unique
  userId       String
  expires      DateTime
  users        users    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model users {
  id             String          @id
  email          String          @unique
  password       String?
  name           String?
  imageUrl       String?
  role           Role            @default(GUEST)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime
  upgradeRequest UpgradeRequest?
  accounts       accounts[]
  inquiries      inquiries[]
  messages       messages[]
  orders         orders[]
  sessions       sessions[]

  @@index([createdAt])
}

model verification_tokens {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model admin_bank_details {
  id            String   @id
  bankName      String
  accountNumber String
  accountName   String
  updatedAt     DateTime @updatedAt
}

model UpgradeRequest {
  id        String        @id @default(uuid())
  userId    String        @unique
  status    UpgradeStatus @default(PENDING)
  message   String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  users     users         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("upgrade_requests")
}

enum InquiryStatus {
  OPEN
  REPLIED
  CLOSED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  PAYSTACK
  BANK_TRANSFER
  CASH_ON_DELIVERY
}

enum Role {
  GUEST
  WHOLESALER
  ADMIN
}

enum UpgradeStatus {
  PENDING
  APPROVED
  REJECTED
}
